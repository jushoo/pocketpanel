{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegisterRequest",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50
    },
    "password": {
      "type": "string",
      "minLength": 8
    }
  },
  "required": ["username", "password"]
}
